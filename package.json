{
  "name": "tracker-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.1",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm -r --parallel --filter @tracker/api --filter @tracker/web dev",
    "build": "corepack pnpm run db:generate && corepack pnpm -r build",
    "typecheck": "corepack pnpm run db:generate && corepack pnpm -r typecheck",
    "test": "corepack pnpm run db:generate && corepack pnpm --filter @tracker/api test",
    "db:generate": "corepack pnpm --filter @tracker/db prisma:generate",
    "db:migrate": "corepack pnpm --filter @tracker/db prisma:migrate",
    "db:seed": "corepack pnpm --filter @tracker/db prisma:seed",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
